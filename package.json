{
  "name": "go-link-auto",
  "description": "Automatically replaces go/links with hyperlinks.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "compile": "tsc --noEmit",
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "zip": "rm -rf ./dist && pnpm build && node scripts/package.js"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-web-extension": "^4.1.4",
    "webextension-polyfill": "^0.12.0",
    "zip-a-folder": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
